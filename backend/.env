# Serveur
PORT=5000
NODE_ENV=development
# MongoDB
MONGO_URI=mongodb://localhost:27017/applauncher
# JWT
JWT_SECRET=mon_super_secret_123456789
JWT_EXPIRES_IN=7d
# URL du frontend (CORS)
CLIENT_URL=http://localhost:5173