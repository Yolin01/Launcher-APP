{
  "name": "applauncher",
  "version": "1.0.0",
  "description": "Lanceur d'applications avec thèmes",
  "main": "electron/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "npm run build:frontend && electron-builder",
    "build:frontend": "npm run build --prefix frontend",
    "start": "electron ."
  },
  "build": {
    "appId": "com.applauncher.app",
    "productName": "AppLauncher",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AppLauncher"
    }
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
